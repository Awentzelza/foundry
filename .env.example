# --- Public (safe to expose; bundled into the client) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Server-only (never prefix with VITE_) ---
# Used by /api/* edge functions.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Bearer secret Claude sends to /api/push-app and /api/archive-app.
FOUNDRY_PUSH_SECRET=set-to-any-long-random-string

# GitHub token used by /api/push-app to commit new app modules to the repo.
# Needs `repo` scope. Without this, push-app falls back to metadata-only mode.
GITHUB_TOKEN=
GITHUB_OWNER=Awentzelza
GITHUB_REPO=foundry
GITHUB_DEFAULT_BRANCH=main

# Optional: Anthropic API key for any server-side Claude calls.
ANTHROPIC_API_KEY=
